// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "prettier": {
    "allowed": false
  },
  "completions": {
    "lsp_insert_mode": "replace"
  },
  "status_bar": {
    "line_endings_button": true
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "use_smartcase_search": true,
  "minimum_contrast_for_highlights": 50.0,
  "preferred_line_length": 100,
  "gutter": {
    "line_numbers": true,
  },
  "redact_private_values": false,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "edit_predictions": {
    "provider": "codestral",
    "mode": "subtle",
  },
  "agent": {
    "dock": "right",
    "play_sound_when_agent_done": "always",
    "default_profile": "ask",
    "default_model": {
      "provider": "mistral",
      "model": "codestral-latest",
    },
    "model_parameters": [],
  },
  "lsp_highlight_debounce": 0,
  "diagnostics": {
    "inline": {
      "enabled": true
    },
    "lsp_pull_diagnostics": {
      "debounce_ms": 0,
    },
  },
  "hard_tabs": false,
  "vim_mode": false,
  "project_panel": {
    "diagnostic_badges": true,
    "git_status_indicator": true,
    "bold_folder_labels": false,
    "dock": "left",
    "hide_hidden": false,
    "hide_root": true,
    "indent_size": 16,
    "entry_spacing": "standard",
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "file_finder": {
    "modal_max_width": "medium",
  },
  "when_closing_with_no_tabs": "keep_window_open",
  "scrollbar": {
    "diagnostics": "warning",
    "git_diff": false,
    "show": "auto",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "git_panel": {
    "file_icons": true,
    "tree_view": true,
    "collapse_untracked_diff": true,
    "sort_by_path": true,
    "dock": "right",
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true,
  },
  "title_bar": {
    "show_menus": false,
  },
  "calls": {
    "mute_on_join": true,
  },
  "terminal": {
    "show_count_badge": true,
    "toolbar": {
      "breadcrumbs": false
    },
    "copy_on_select": true,
    "shell": {
      "program": "fish",
    },
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv"],
        "activate_script": "fish",
      },
    },
  },
  "use_system_window_tabs": false,
  "tabs": {
    "show_diagnostics": "errors",
    "close_position": "right",
    "show_close_button": "always",
    "file_icons": true,
    "git_status": true,
  },
  "search": {
    "whole_word": false,
    "case_sensitive": true,
    "center_on_match": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 0,
    },
  },
  "toolbar": {
    "quick_actions": false,
    "selections_menu": false,
    "code_actions": false,
    "breadcrumbs": false,
  },
  "minimap": {
    "thumb_border": "none",
    "max_width_columns": 70,
    "thumb": "hover",
    "show": "never",
  },
  // File scan exclusions, hide on the file explorer and search
  "file_scan_exclusions": [
    // "**/.git",
    // "**/.svn",
    // "**/.hg",
    // "**/CVS",
    // "**/.DS_Store",
    // "**/Thumbs.db",
    // "**/.classpath",
    // "**/.settings",
    // above is default from Zed
    // "**/out",
    // "**/dist",
    // "**/.husky",
    // "**/.turbo",
    // "**/.vscode-test",
    // "**/.vscode",
    // "**/.next",
    // "**/.storybook",
    // "**/.tap",
    // "**/.nyc_output",
    // "**/report",
    // "**/node_modules"
  ],
  "relative_line_numbers": "enabled",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16.0,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Macchiato",
    "dark": "Catppuccin Macchiato"
  },
  "languages": {
    "Markdown": {
      // Wrap text according to the previously defined preferred line length.
      "colorize_brackets": true,
      "soft_wrap": "prefer_line",

      // do not remove any trailing whitespace since line breaks in
      // lists (without adding a new punctuation) rely on whitespaces.
      "remove_trailing_whitespace_on_save": true,
    },
    "LaTeX": {
      // Same as in Markdown
      "soft_wrap": "prefer_line",
      // "soft_wrap": "editor_width"

      // Just a matter of linking. I like more compact fluent text-
      "preferred_line_length": 110,
    },
    "Python": {
      "remove_trailing_whitespace_on_save": true,
      "use_auto_surround": true,
      "use_autoclose": true,
      "show_completions_on_input": true,
      "language_servers": ["pyright", "ruff"], // if I don't explicitly enable only one, I will see 2 tooltips (pyright and pylsp)
      "extend_comment_on_newline": false,
      "ensure_final_newline_on_save": true,
      "enable_language_server": true,
    },
  },
}
